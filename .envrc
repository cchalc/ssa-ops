export UV_PROJECT_ENVIRONMENT=$HOME/.virtualenvs/$(basename "$PWD")

# Databricks configuration
# fevm-cjc: Infrastructure deployment (Lakebase, Apps) - used by DAB
# logfood: Data queries (SQL Warehouse, Unity Catalog tables)
export DATABRICKS_CONFIG_PROFILE=fevm-cjc
export DATABRICKS_DATA_PROFILE=logfood

# Load .env file if it exists (for local secrets)
dotenv_if_exists .env
